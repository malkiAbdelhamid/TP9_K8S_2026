#FROM openjdk:25-rc
#COPY target/ms-ordonnance*.jar ms-ordonnance.jar
#CMD java -jar /ms-ordonnance.jar

# Use Eclipse Temurin JDK 25 as base image
FROM eclipse-temurin:25-jdk-noble AS builder

WORKDIR /app

# Copy Maven wrapper and pom.xml first (layer caching)
COPY mvnw .
COPY .mvn .mvn
COPY pom.xml .

# Fix execute permission on Maven wrapper
RUN chmod +x mvnw

# Download dependencies (cached layer)
RUN ./mvnw dependency:go-offline -B

# Copy source code
COPY src src

# Build the application
RUN ./mvnw package -DskipTests -B

# ---- Runtime Stage ----
FROM eclipse-temurin:25-jre-noble

WORKDIR /app

# Create non-root user for security
RUN groupadd --system spring && useradd --system --gid spring spring

# Copy the built JAR from builder stage
COPY --from=builder /app/target/*.jar app.jar

# Set ownership
RUN chown spring:spring app.jar

USER spring

EXPOSE 8082

ENTRYPOINT ["java", "-jar", "app.jar"]


